{
  "name": "cannibalizr",
  "version": "5.0.7",
  "description": "Turns an old pile of rusty files into a new json data source",
  "main": "dist/index.js",
  "type": "module",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.cjs",
    "default": "./dist/index.js"
  },
  "scripts": {
    "_prep": "node -e 'require(\"fs\").rmSync(\"./dist\",{recursive:true,force:true})'",
    "prepublishOnly": "npm run _prep && babel ./lib/index.js -o ./dist/index.cjs && node -e 'require(\"fs\").copyFileSync(\"./lib/index.js\", \"./dist/index.js\");'",
    "pretest": "node -e 'require(\"fs\").rmSync(\"./coverage\",{recursive:true,force:true});require(\"fs\").mkdirSync(\"./coverage\",{recursive:true})'",
    "test": "node --test --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info ./tests/unit/**",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localnerve/cannibalizr.git"
  },
  "keywords": [
    "data",
    "capture",
    "regex",
    "strings",
    "multiple",
    "files",
    "json"
  ],
  "files": [
    "dist/"
  ],
  "author": "Alex Grant <alex@localnerve> (https://www.localnerve.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/localnerve/cannibalizr/issues"
  },
  "homepage": "https://github.com/localnerve/cannibalizr#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@babel/cli": "^8.0.1",
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/localnerve"
    },
    {
      "type": "paypal",
      "url": "https://www.paypal.com/ncp/payment/DHCB5GUYMGX5U"
    }
  ]
}
